GEMINI_VERTEX_PROJECT=
GEMINI_VERTEX_LOCATION=europe-west1
# Прокси на generativelanguage.googleapis.com, если нужен EU/US relay:
GEMINI_API_BASE_URL=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GA4_PROPERTY_ID=
