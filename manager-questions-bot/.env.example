# Telegram bot token (BotFather)
TELEGRAM_MANAGER_QUESTIONS_BOT_TOKEN=

# Google Sheet target
MANAGER_QUESTIONS_SHEET_ID=
# optional; defaults to "Лист1"
MANAGER_QUESTIONS_SHEET_NAME=Лист1

# Service account with Editor access to the sheet (reuse existing codex-pressa@...)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Do not collect messages from these authors (comma-separated, without @).
# Anna_Last and marija_pat are always excluded by default even if this is empty.
EXCLUDED_USERNAMES=Anna_Last,marija_pat
# Optional: exclude by numeric Telegram user id (comma-separated)
EXCLUDED_USER_IDS=

# Optional: only listen in these chat ids (comma-separated). Empty = all chats.
TELEGRAM_MANAGER_QUESTIONS_CHAT_IDS=

# true (default) = write only messages that look like questions; false = write all
ONLY_QUESTIONS=true
